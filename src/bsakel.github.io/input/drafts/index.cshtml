@foreach (IDocument child in Document.GetChildren())
{
    <article class="post-card">
        <h2>
            <a href="@child.GetLink()">@child.GetString("Title")</a>
            <span class="draft-badge">[draft]</span>
        </h2>
        <div class="post-meta">
            <time>@child.GetDateTime("Published").ToString("yyyy-MM-dd")</time>
            @if (child.ContainsKey("Tags"))
            {
                <span class="post-tags">
                    @foreach (var tag in child.GetList<string>("Tags"))
                    {
                        <a href="/tags/@(tag.ToLower().Replace(" ", "-"))/" class="tag">[@tag]</a>
                    }
                </span>
            }
        </div>
    </article>
}
